PORT=4173
NODE_ENV=development

# Cliniko starts as read-only. Report PDF upload is separately gated below.
# Use a Cliniko test account API key first. Do not use a real patient-data key until confirmed.
CLINIKO_API_KEY=
CLINIKO_BASE_URL=https://api.au1.cliniko.com/v1
CLINIKO_USER_AGENT=Refine Physio Mobile (admin@refinephysio.com.au)
CLINIKO_POLL_ENABLED=false
CLINIKO_APPOINTMENT_CREATE_ENABLED=false
CLINIKO_APPOINTMENT_WRITE_ENABLED=false
CLINIKO_PATIENT_CREATE_ENABLED=false
CLINIKO_REPORT_UPLOAD_ENABLED=false
CLINIKO_REPORT_UPLOAD_AUTO_ENABLED=false
CLINIKO_NOTE_UPLOAD_ENABLED=false
CLINIKO_NOTE_UPLOAD_AUTO_ENABLED=false

# Optional for staging/test only. Minimum enforced by the app is 15 seconds.
CLINIKO_POLL_SECONDS=
CLINIKO_POLL_MINUTES=5
CLINIKO_MIN_REQUEST_INTERVAL_MS=350
CLINIKO_MAX_SYNC_PAGES=20

# Set before connecting a real Cliniko account. Appointments before this
# Brisbane date are ignored, and patients are only imported from synced appointments.
CLINIKO_SYNC_START_DATE=
CLINIKO_APPOINTMENT_SYNC_PAST_DAYS=14
CLINIKO_APPOINTMENT_SYNC_FUTURE_DAYS=90

# Optional: force one Cliniko business/location during testing.
# Leave blank to let Admin > Cliniko enable one imported location.
CLINIKO_ACTIVE_BUSINESS_ID=
CLINIKO_ALLOW_MULTIPLE_LOCATIONS=false

# Optional: force one or more Cliniko practitioners during testing.
# Leave blank to let Admin > Cliniko enable imported practitioners.
CLINIKO_ACTIVE_PRACTITIONER_IDS=
CLINIKO_ALLOW_MULTIPLE_PRACTITIONERS=false

# Use this for staging/production bootstrap so demo seed data is never copied.
REFINE_EMPTY_DB=false

# For web hosting with a persistent disk, point app data outside the deploy folder.
# Example on Render: /var/data/refine
REFINE_DATA_DIR=

# Production safety guard. Do not set this to true until real login/session
# middleware has replaced the prototype role switcher.
REFINE_AUTH_IMPLEMENTED=false

# Required once NODE_ENV=production and the app has been moved to PostgreSQL/auth.
DATABASE_URL=
SESSION_SECRET=
